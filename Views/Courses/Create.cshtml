@model StudentManager.Models.Course
@{
    ViewData["Title"] = "新增课程";
}

<div class="card form-card">
    <div class="card-header">
        <h1 class="h3 mb-0"><i class="fas fa-plus-circle"></i> @ViewData["Title"]</h1>
    </div>
    <div class="card-body">
        <form asp-action="Create">
            <div class="form-group">
                <label asp-for="CourseName" class="control-label"></label>
                <input asp-for="CourseName" class="form-control" placeholder="请输入课程名称" />
            </div>
            <div class="form-group">
                <label asp-for="Teacher" class="control-label"></label>
                <input asp-for="Teacher" class="form-control" placeholder="请输入授课教师" />
            </div>
            <div class="form-group mt-3">
                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> 保存</button>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left"></i> 返回列表</a>
            </div>
        </form>
    </div>
</div>
