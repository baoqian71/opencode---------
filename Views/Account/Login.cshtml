@model StudentManager.Models.User
@{
    ViewData["Title"] = "登录";
}

<div class="auth-card">
    <div class="card">
        <div class="card-body">
            <h2><i class="fas fa-sign-in-alt"></i> @ViewData["Title"]</h2>

            @if (!string.IsNullOrEmpty(ViewBag.Error))
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }

            <form asp-action="Login">
                <div class="form-group">
                    <label asp-for="Username" class="control-label"></label>
                    <input asp-for="Username" class="form-control" placeholder="请输入用户名" />
                </div>
                <div class="form-group">
                    <label asp-for="Password" class="control-label"></label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="请输入密码" />
                </div>
                <div class="form-group mt-3">
                    <input type="submit" value="登录" class="btn btn-primary" />
                </div>
            </form>

            <div class="auth-footer">
                <a asp-action="Register"><i class="fas fa-user-plus"></i> 还没有账号？注册</a>
            </div>
        </div>
    </div>
</div>
