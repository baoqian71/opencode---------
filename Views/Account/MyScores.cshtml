@model List<StudentManager.Models.Score>
@{
    ViewData["Title"] = "我的成绩";
    var studentName = ViewBag.StudentName ?? "未知";
}

<div class="card">
    <div class="card-header">
        <h1 class="h3"><i class="fas fa-star"></i> @ViewData["Title"] - @studentName</h1>
    </div>
    <div class="card-body">
        @if (Model.Count == 0)
        {
            <div class="empty-state">
                <i class="fas fa-file-alt"></i>
                <p>暂无成绩记录</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>课程</th>
                            <th>成绩</th>
                            <th>录入日期</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><i class="fas fa-book text-primary me-1"></i> @(item.Course?.CourseName)</td>
                                <td><span class="badge @(item.Grade >= 60 ? "bg-success" : "bg-danger")">@item.Grade.ToString("F2")</span></td>
                                <td><i class="far fa-calendar-alt text-muted me-1"></i> @item.ScoreDate.ToString("yyyy-MM-dd")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
