@model List<StudentManager.Models.User>
@{
    ViewData["Title"] = "用户管理";
}

<div class="card">
    <div class="card-header">
        <h1 class="h3 mb-0"><i class="fas fa-users-cog"></i> @ViewData["Title"]</h1>
    </div>
    <div class="card-body">
        @if (Model.Count == 0)
        {
            <div class="empty-state">
                <i class="fas fa-users"></i>
                <p>暂无用户记录</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>用户名</th>
                            <th>角色</th>
                            <th class="text-center" style="width: 160px;">操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><i class="fas fa-user-circle text-primary me-1"></i> <strong>@item.Username</strong></td>
                                <td>
                                    @if (item.Role == "Admin")
                                    {
                                        <span class="badge bg-warning text-dark"><i class="fas fa-shield-alt"></i> 管理员</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info"><i class="fas fa-user"></i> 用户</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-1" title="编辑">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="删除">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
